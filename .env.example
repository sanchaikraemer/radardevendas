# Fechou — variáveis de ambiente
#
# Chave da OpenAI. Usada para:
#   (1) análise da negociação + geração das 3 sugestões (chat/GPT) — JÁ usado no MVP
#   (2) transcrição de áudio do WhatsApp (Whisper) — entra na fase de áudio
# Sem essa chave o app roda em modo demo (sugestões-fallback).
OPENAI_API_KEY=

# Modelo de chat para a análise (opcional). Padrão: gpt-4o.
# Para reduzir custo (respostas um pouco mais simples), use por ex.: gpt-4o-mini
OPENAI_MODEL=gpt-4o

# Modelo de transcrição (opcional). Padrão: whisper-1
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- Supabase (opcional: banco + login) ---
# Sem essas variáveis o app roda SEM login e SEM persistência (modo local).
# Com elas, conversas importadas ficam salvas na conta do corretor.
# Pegue em: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
